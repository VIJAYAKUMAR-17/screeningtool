DATABASE_URL=sqlite:///./sanctions.db

# Clerk session-token verification. CLERK_ISSUER is required.
# Example issuer: https://your-clerk-instance.clerk.accounts.dev

CLERK_JWKS_URL=
CLERK_JWT_KEY=
CLERK_AUDIENCE=
CLERK_ISSUER=https://neutral-buzzard-68.clerk.accounts.dev
CLERK_AUTHORIZED_PARTIES=http://localhost:5173
CLERK_REQUIRE_ORGANIZATION=true

# Comma-separated browser origins allowed by CORS.
# Leave empty for same-origin only (production default when the SPA is served by this API).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Tier 1 CSL API
TIER1_CSL_API_KEY=
TIER1_CSL_BASE_URL=https://data.trade.gov/consolidated_screening_list/v1
TIER1_CSL_TIMEOUT_SECONDS=20
